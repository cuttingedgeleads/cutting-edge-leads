generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CONTRACTOR
}

enum UnlockStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                   String
  businessName           String              @default("")
  passwordHash           String
  role                   Role                @default(CONTRACTOR)
  phone                  String              @default("")
  serviceCities          String              @default("")
  timezone               String              @default("America/Chicago")
  preferredContactMethod String              @default("EMAIL")
  notifyNewLeads         Boolean             @default(true)
  notifyJobTypes         Json?
  notifyUnlockApproved   Boolean             @default(true)
  notifyMarketing        Boolean             @default(false)
  notifySms              Boolean             @default(false)
  failedLoginAttempts    Int                 @default(0)
  lockedUntil            DateTime?
  createdAt              DateTime            @default(now())
  unlocks                LeadUnlockRequest[] @relation("UserUnlocks")
  pushSubscriptions      PushSubscription[]
  auditLogs              AuditLog[]
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  email     String?
  ip        String?
  details   String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id          String               @id @default(cuid())
  name        String               @default("")
  email       String               @default("")
  phone       String               @default("")
  jobType     String
  description String
  address     String
  city        String
  state       String
  zip         String
  price       Int
  createdAt   DateTime             @default(now())
  photos      LeadPhoto[]
  unlocks     LeadUnlockRequest[]  @relation("LeadUnlocks")
}

model LeadPhoto {
  id      String @id @default(cuid())
  leadId  String
  url     String
  lead    Lead   @relation(fields: [leadId], references: [id])
}

model LeadUnlockRequest {
  id           String       @id @default(cuid())
  leadId       String
  contractorId String
  status       UnlockStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  approvedAt   DateTime?

  lead         Lead         @relation("LeadUnlocks", fields: [leadId], references: [id])
  contractor   User         @relation("UserUnlocks", fields: [contractorId], references: [id])

  @@unique([leadId, contractorId])
}
